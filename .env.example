# ── LLM Provider ──────────────────────────────────────────────────
# "ollama"    → local Gemma (development, free)
# "openai"    → GPT-4o (production)
# "anthropic" → Claude 3.5 Sonnet (production)
LLM_PROVIDER=ollama

# ── Ollama (dev) ───────────────────────────────────────────────────
OLLAMA_MODEL=gemma4:26b
OLLAMA_BASE_URL=http://localhost:11434

# ── Manager Tier (Local Dev) ───────────────────────────────────────
# Use a smaller model like llama3.1:8b for high-speed coordination
MANAGER_LLM_PROVIDER=ollama
MANAGER_OLLAMA_MODEL=llama3.1:8b

# ── OpenAI (prod) ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Anthropic (prod) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ── Serper (Search API) ───────────────────────────────────────────
SERPER_API_KEY=
