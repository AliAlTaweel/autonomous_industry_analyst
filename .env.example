# ── LLM Provider ──────────────────────────────────────────────────
# "ollama"    → local Gemma (development, free)
# "openai"    → GPT-4o (production)
# "anthropic" → Claude 3.5 Sonnet (production)
LLM_PROVIDER=ollama

# ── Ollama (dev) ───────────────────────────────────────────────────
OLLAMA_MODEL=gemma4:26b
OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI (prod) ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Anthropic (prod) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ── Serper (Search API) ───────────────────────────────────────────
SERPER_API_KEY=
